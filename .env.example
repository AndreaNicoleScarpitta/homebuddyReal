# Home Buddy — environment variable template
# Copy to .env for local dev. On Railway, set these via the dashboard.

# ──────────────── Core ────────────────
# Provided automatically by Railway when you attach a Postgres service
DATABASE_URL=postgresql://user:pass@host:5432/db
PORT=5000
NODE_ENV=production

# Random 32+ char string. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Public base URL of your app — used for OAuth redirects & webhook URLs
OAUTH_BASE_URL=https://homebuddy.space

# ──────────────── Auth: Google OAuth ────────────────
# From https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────── Object storage: Cloudflare R2 ────────────────
# From https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=homebuddy-prod
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Only set if you enable "Public Development URL" on the R2 bucket for public assets
R2_PUBLIC_BASE_URL=

# ──────────────── Stripe billing ────────────────
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_PREMIUM=price_...

# ──────────────── AI / integrations ────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# Backup slot — code falls back to this if the above isn't set
OPENAI_API_KEY=

# ──────────────── Email (optional but recommended) ────────────────
# For transactional email (signup confirmation, password reset)
RESEND_API_KEY=

# ──────────────── Google Analytics 4 (optional) ────────────────
# Required only for SEO/marketing agents
GA4_PROPERTY_ID=
# Full service-account JSON on one line (escape newlines in the private_key)
GA4_SERVICE_ACCOUNT_JSON=

# ──────────────── Frontend-accessible env (must be prefixed VITE_) ────────────────
# For Google Places address autocomplete
VITE_GOOGLE_PLACES_API_KEY=
